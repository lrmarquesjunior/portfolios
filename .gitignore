# ============================================================
# Kiro IDE
# ============================================================
# Arquivos de configuração interna do Kiro (não são relevantes
# para quem visualiza o portfólio)
.kiro/**/.config.kiro
.kiro/settings/
.kiro/hooks/

# Specs do Kiro: manter requirements.md e design.md (documentação útil)
# mas ignorar arquivos de estado interno
**/.kiro/specs/**/.config.kiro

# ============================================================
# Node.js / Lambda
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
dist/
build/
.env
.env.local
.env.*.local

# ============================================================
# AWS / Terraform / CDK
# ============================================================
# Credenciais e configurações locais da AWS — NUNCA subir
.aws/
*.pem
*.key
credentials

# CDK
cdk.out/
cdk.context.json

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
.terraform.lock.hcl

# SAM
.aws-sam/
samconfig.toml

# ============================================================
# Segredos e variáveis de ambiente
# ============================================================
.env
.env.*
*.secret
secrets.json
secrets.yaml
secrets.yml

